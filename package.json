{
  "name": "ade",
  "version": "0.1.0",
  "description": "Agent Development Environment — the IDE for teams of AI agents",
  "main": "dist/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"npx wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx ts-node src/main/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agents",
    "ide",
    "ai",
    "electron"
  ],
  "author": "feral",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0"
  }
}
